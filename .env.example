PORT=3001
NODE_ENV=development

# Leave blank locally — the backend uses SQLite automatically.
# On Render, this is injected from the database Blueprint — you never set it manually.
# DATABASE_URL=

# Optional: custom SQLite path (defaults to ./data.sqlite)
# SQLITE_PATH=./data.sqlite

# Groq API key for AI-generated weekly briefs (/api/weekly).
# Free tier: 14,400 req/day — get a key at https://console.groq.com
# Without this key the endpoint still works but returns template text instead.
GROQ_API_KEY=
